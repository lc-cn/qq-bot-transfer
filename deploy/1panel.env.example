# 复制到服务器项目目录为 .env，或在 1Panel 运行环境旁挂载同目录
# 域名、数据库账号请改成你的实际值

NODE_ENV=production
HOSTNAME=0.0.0.0
PORT=3000

# 本机 Postgres（与 1Panel「数据库」或 apt 安装的实例一致）
DATABASE_URL=postgresql://qqbot:YOUR_PASSWORD@127.0.0.1:5432/qqbot

AUTH_SECRET=
ENCRYPTION_KEY=
AUTH_URL=https://bot.example.com
PUBLIC_URL=https://bot.example.com
AUTH_STRICT_URL=true
GATEWAY_WS_URL=wss://bot.example.com/websocket

AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

WEBHOOK_EVENT_RETENTION_DAYS=30
WEBHOOK_EVENT_MAX_PER_BOT=5000
